generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("MEMBER")
  groupId      String?
  group        Group?   @relation(fields: [groupId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLogin    DateTime?
  isActive     Boolean  @default(true)
  
  studyProgress StudyProgress[]
  
  @@index([groupId])
  @@index([role])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  meetingDay  String
  meetingTime String
  location    String?
  description String?
  healthScore Int      @default(70)
  memberCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users        User[]
  missionStats MissionStats?
  prayers      Prayer[]
  attendances  Attendance[]
  
  @@index([name])
}

model Prayer {
  id          String   @id @default(cuid())
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id])
  memberName  String
  request     String
  status      String   @default("ACTIVE")
  isPrivate   Boolean  @default(false)
  category    String?
  urgency     String   @default("medium")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  answeredAt  DateTime?
  testimony   String?
  
  @@index([groupId])
  @@index([status])
}

model Attendance {
  id         String   @id @default(cuid())
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id])
  memberId   String
  memberName String
  date       DateTime @default(now())
  status     String   @default("PRESENT")
  notes      String?
  
  @@unique([groupId, memberId, date])
  @@index([groupId])
  @@index([date])
}

model StudyProgress {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  groupId    String
  seriesId   String
  lessonId   Int
  completed  Boolean  @default(false)
  completedAt DateTime?
  notes      String?
  updatedAt  DateTime @updatedAt
  
  @@unique([userId, seriesId, lessonId])
  @@index([userId])
  @@index([groupId])
}

model MissionStats {
  id             String   @id @default(cuid())
  groupId        String   @unique
  group          Group    @relation(fields: [groupId], references: [id])
  soulWinning    Int      @default(0)
  baptisms       Int      @default(0)
  outreachEvents Int      @default(0)
  prayerRequests Int      @default(0)
  answeredPrayers Int     @default(0)
  updatedAt      DateTime @updatedAt
  
  @@index([groupId])
}
